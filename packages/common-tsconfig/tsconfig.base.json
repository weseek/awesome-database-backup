{
  /* default compiler options */
  "compilerOptions": {
    "strict": true,
    "declaration": true,
    "noResolve": false,
    "preserveConstEnums": true,
    "sourceMap": true,
    "noEmit": false,
    "inlineSources": true,
    "target": "es2022",
    "lib": ["es2022"],
    "module": "commonjs",

    /*
     * Module Resolution Options
     *
     * Workspace packages (e.g. "commands", "storage-service-clients") are resolved
     * via node_modules to their built output ("main"/"types"), NOT aliased to their
     * source. This keeps each package's transitive dependencies resolvable from the
     * package's own node_modules under pnpm's isolated layout, instead of bundling
     * the dependency's source into every consumer's "dist".
     */
    "esModuleInterop": true
  }
}
